---
import type { Language } from '../lib/i18n';
import { getContentByLanguage } from '../lib/content';
import { getLocalizedPath, getAlternateLang } from '../lib/i18n';
import { carBrands } from '../data/car-brands';
import { services } from '../data/services';
import { getCityBySlug } from '../data/cities';
import ComingSoonLink from './ComingSoonLink.astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const content = getContentByLanguage(lang);
const altLang = getAlternateLang(lang);
const currentPath = Astro.url.pathname;

// Strip language prefix to get the base path for the toggle link
function getBasePath(path: string): string {
  if (path.startsWith('/en/')) return path.slice(3);
  if (path === '/en') return '/';
  return path;
}

const basePath = getBasePath(currentPath);
const toggleHref = getLocalizedPath(basePath, altLang);
const toggleLabel = altLang === 'ar' ? 'العربية' : 'English';

function resolveHeaderHref(href: string): string {
  return getLocalizedPath(href, lang);
}

const brandsWithModelPages = new Set(carBrands.filter((brand) => brand.popularity === 'high').map((brand) => brand.slug));
const localizedBrandName = (nameAr: string, nameEn: string) => (lang === 'ar' ? nameAr : nameEn);
const localizedServiceName = (nameAr: string, nameEn: string) => (lang === 'ar' ? nameAr : nameEn);
const riyadh = getCityBySlug('riyadh');
const riyadhNeighborhoods = riyadh?.neighborhoods ?? [];
const servicesQuickLinks = [
  { label: content.header.servicesMenu.pricingLinkLabel, href: '/pricing' },
  { label: content.header.servicesMenu.riyadhLinkLabel, href: '/services/riyadh' },
  { label: content.header.servicesMenu.contactLinkLabel, href: '/contact' },
];

const carsQuickLinks = [
  { label: content.header.carsMenu.blogLinkLabel, href: '/blog' },
  { label: content.header.carsMenu.guidesLinkLabel, href: '/blog' },
  { label: content.header.carsMenu.reportLinkLabel, href: '/contact' },
];
---

<header class="sticky top-0 z-50 w-full border-b-2 border-primary/15 bg-background/90 backdrop-blur-xl" data-site-header>
  <div class="container mx-auto flex h-18 items-center justify-between px-4">
    {/* Logo */}
    <a href={getLocalizedPath('/', lang)} class="flex items-center gap-2.5">
      {lang === 'ar' ? (
        <img src="/logo-ar.svg?v=3" alt="اوتو سيف" width="130" height="36" class="h-9 w-auto" />
      ) : (
        <img src="/logo.svg" alt="AUTO SAVE" width="130" height="36" class="h-9 w-auto" />
      )}
    </a>

    {/* Desktop Navigation */}
    <nav class="hidden md:flex items-center gap-6">
      <a
        href={resolveHeaderHref(content.header.nav[0].href)}
        class="nav-link-hover text-sm font-medium text-muted-foreground transition-colors hover:text-foreground"
      >
        {content.header.nav[0].name}
      </a>

      <div class="relative" data-menu-key="services">
        <button
          type="button"
          class="inline-flex items-center gap-2 rounded-lg px-2 py-1 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground"
          aria-label={content.header.servicesMenu.trigger}
          aria-haspopup="true"
          aria-expanded="false"
          aria-controls="desktop-menu-services"
          data-menu-trigger="services"
        >
          <span>{content.header.servicesMenu.trigger}</span>
          <svg
            class="size-4 transition-transform duration-200"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            aria-hidden="true"
            data-menu-chevron="services"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
          </svg>
        </button>

        <div
          id="desktop-menu-services"
          data-menu-panel="services"
          class="pointer-events-none invisible absolute start-0 top-full z-50 mt-3 w-[min(94vw,60rem)] rounded-2xl border border-border bg-card p-5 opacity-0 shadow-xl transition-all duration-200"
        >
          <div class="grid gap-5 lg:grid-cols-[2fr_1fr]">
            <section>
              <h2 class="font-display text-lg font-semibold text-foreground">{content.header.servicesMenu.title}</h2>
              <p class="mt-1 text-sm text-muted-foreground">{content.header.servicesMenu.description}</p>
              <p class="mt-3 text-xs font-semibold uppercase tracking-wide text-primary">{content.header.servicesMenu.categoriesLabel}</p>

              <div class="mt-3 grid max-h-[60vh] gap-2 overflow-y-auto pe-1">
                {services.map((service) => (
                  <details class="rounded-lg border border-border bg-background/60 p-3">
                    <summary class="cursor-pointer list-none text-sm font-semibold text-foreground">
                      <span>{localizedServiceName(service.nameAr, service.nameEn)}</span>
                    </summary>
                    <div class="mt-2 space-y-2 border-t border-border pt-2">
                      <a
                        href={getLocalizedPath(`/services/${service.slug}`, lang)}
                        class="inline-flex rounded-md border border-primary/30 px-2.5 py-1.5 text-xs font-medium text-primary transition-colors hover:bg-primary/5"
                      >
                        {content.header.servicesMenu.viewServiceLabel}
                      </a>

                      {riyadhNeighborhoods.length > 0 && (
                        <div>
                          <p class="text-xs font-medium text-muted-foreground">{content.header.servicesMenu.areasLabel}</p>
                          <div class="mt-2 flex flex-wrap gap-1.5">
                            {riyadhNeighborhoods.slice(0, 6).map((neighborhood) => (
                              <a
                                href={getLocalizedPath(`/services/riyadh/${neighborhood.slug}`, lang)}
                                class="rounded-md border border-border bg-card px-2 py-1 text-xs text-foreground transition-colors hover:border-primary/40 hover:text-primary"
                              >
                                {lang === 'ar' ? neighborhood.nameAr : neighborhood.nameEn}
                              </a>
                            ))}
                          </div>
                          <p class="mt-2 text-xs text-muted-foreground">{content.header.servicesMenu.neighborhoodsHintLabel}</p>
                        </div>
                      )}
                    </div>
                  </details>
                ))}
              </div>
            </section>

            <aside class="rounded-xl border border-border bg-secondary/35 p-4">
              <h3 class="font-display text-base font-semibold text-foreground">{content.header.servicesMenu.quickLinksLabel}</h3>
              <div class="mt-3 space-y-2">
                {servicesQuickLinks.map((link) => (
                  <a
                    href={resolveHeaderHref(link.href)}
                    class="block rounded-lg border border-border bg-card px-3 py-2 text-sm font-medium text-foreground transition-colors hover:border-primary/40 hover:text-primary"
                  >
                    {link.label}
                  </a>
                ))}
              </div>
            </aside>
          </div>
        </div>
      </div>

      <div class="relative" data-menu-key="cars">
        <button
          type="button"
          class="inline-flex items-center gap-2 rounded-lg px-2 py-1 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground"
          aria-label={content.header.carsMenu.trigger}
          aria-haspopup="true"
          aria-expanded="false"
          aria-controls="desktop-menu-cars"
          data-menu-trigger="cars"
        >
          <span>{content.header.carsMenu.trigger}</span>
          <svg
            class="size-4 transition-transform duration-200"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            aria-hidden="true"
            data-menu-chevron="cars"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
          </svg>
        </button>

        <div
          id="desktop-menu-cars"
          data-menu-panel="cars"
          class="pointer-events-none invisible absolute start-0 top-full z-50 mt-3 w-[min(94vw,68rem)] rounded-2xl border border-border bg-card p-5 opacity-0 shadow-xl transition-all duration-200"
        >
          <div class="grid gap-5 lg:grid-cols-[2fr_1fr]">
            <section>
              <h2 class="font-display text-lg font-semibold text-foreground">{content.header.carsMenu.title}</h2>
              <p class="mt-1 text-sm text-muted-foreground">{content.header.carsMenu.description}</p>
              <p class="mt-3 text-xs font-semibold uppercase tracking-wide text-primary">{content.header.carsMenu.categoriesLabel}</p>

              <div class="mt-3 grid max-h-[60vh] gap-2 overflow-y-auto pe-1">
                {carBrands.map((brand) => (
                  <details class="rounded-lg border border-border bg-background/60 p-3">
                    <summary class="cursor-pointer list-none text-sm font-semibold text-foreground">
                      <span>{localizedBrandName(brand.nameAr, brand.nameEn)}</span>
                    </summary>
                    <div class="mt-2 space-y-2 border-t border-border pt-2">
                      <a
                        href={getLocalizedPath(`/car-ac/${brand.slug}`, lang)}
                        class="inline-flex rounded-md border border-primary/30 px-2.5 py-1.5 text-xs font-medium text-primary transition-colors hover:bg-primary/5"
                      >
                        {content.header.carsMenu.viewBrandLabel}
                      </a>

                      {brandsWithModelPages.has(brand.slug) ? (
                        <div>
                          <p class="text-xs font-medium text-muted-foreground">{content.header.carsMenu.modelsLabel}</p>
                          <div class="mt-2 flex flex-wrap gap-1.5">
                            {brand.models.map((model) => (
                              <a
                                href={getLocalizedPath(`/car-ac/${brand.slug}/${model.slug}`, lang)}
                                class="rounded-md border border-border bg-card px-2 py-1 text-xs text-foreground transition-colors hover:border-primary/40 hover:text-primary"
                              >
                                {localizedBrandName(model.nameAr, model.nameEn)}
                              </a>
                            ))}
                          </div>
                        </div>
                      ) : (
                        <div>
                          <p class="text-xs font-medium text-muted-foreground">{content.header.carsMenu.modelsLabel}</p>
                          <div class="mt-2 flex flex-wrap gap-1.5">
                            {brand.models.map((model) => (
                              <span class="rounded-md border border-border bg-card px-2 py-1 text-xs text-muted-foreground">
                                {localizedBrandName(model.nameAr, model.nameEn)}
                              </span>
                            ))}
                          </div>
                          <p class="mt-2 text-xs text-muted-foreground">{content.header.carsMenu.noModelPagesLabel}</p>
                        </div>
                      )}
                    </div>
                  </details>
                ))}
              </div>
            </section>

            <aside class="rounded-xl border border-border bg-secondary/35 p-4">
              <h3 class="font-display text-base font-semibold text-foreground">{content.header.carsMenu.quickLinksLabel}</h3>
              <div class="mt-3 space-y-2">
                {carsQuickLinks.map((link) => (
                  <a
                    href={resolveHeaderHref(link.href)}
                    class="block rounded-lg border border-border bg-card px-3 py-2 text-sm font-medium text-foreground transition-colors hover:border-primary/40 hover:text-primary"
                  >
                    {link.label}
                  </a>
                ))}
              </div>
            </aside>
          </div>
        </div>
      </div>

      {content.header.nav.slice(1).map((item) => (
        <a
          href={resolveHeaderHref(item.href)}
          class="nav-link-hover text-sm font-medium text-muted-foreground transition-colors hover:text-foreground"
        >
          {item.name}
        </a>
      ))}
    </nav>

    {/* Actions */}
    <div class="flex items-center gap-3">

      {/* Language toggle */}
      <a
        href={toggleHref}
        class="text-sm font-semibold text-primary hover:text-primary/80 transition-colors px-3.5 py-1.5 rounded-full border border-primary/30 hover:bg-primary/5"
      >
        {toggleLabel}
      </a>

      {/* CTA Button */}
      <ComingSoonLink
        href={getLocalizedPath('/contact', lang)}
        lang={lang}
        class="hidden sm:inline-flex items-center justify-center rounded-lg gold-gradient gold-shimmer px-5 py-2.5 text-sm font-semibold text-white shadow-md transition hover:shadow-lg hover:shadow-primary/20"
      >
        {content.header.quoteButton}
      </ComingSoonLink>

      {/* Mobile menu button */}
      <button
        type="button"
        class="md:hidden inline-flex items-center justify-center rounded-lg p-2 text-muted-foreground hover:text-foreground hover:bg-secondary"
        aria-label={content.header.menuToggle}
        id="mobile-menu-btn"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </div>

  {/* Mobile Navigation */}
  <div id="mobile-menu" class="mobile-menu-enter md:hidden">
    <div>
      <nav class="container mx-auto flex max-h-[calc(100dvh-4.5rem)] flex-col gap-1 overflow-y-auto overscroll-y-contain border-t-2 border-primary/10 bg-background px-4 py-5">
        {content.header.nav.map((item) => (
          <a
            href={resolveHeaderHref(item.href)}
            class="text-sm font-medium text-muted-foreground hover:text-foreground hover:bg-secondary/60 py-2.5 px-3 rounded-lg transition-colors"
          >
            {item.name}
          </a>
        ))}

        <details class="group mt-2 rounded-xl border border-border bg-secondary/25 p-3" data-mobile-submenu>
          <summary class="flex min-h-11 cursor-pointer list-none items-center justify-between rounded-lg px-1 text-sm font-semibold text-foreground">
            <span>{content.header.servicesMenu.trigger}</span>
            <svg
              class="size-4 text-muted-foreground transition-transform duration-200 group-open:rotate-180"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
            </svg>
          </summary>

          <div class="mobile-submenu-panel">
            <div class="mobile-submenu-panel-inner mt-2 border-t border-border pt-3">
              <h2 class="font-display text-base font-semibold text-foreground">{content.header.servicesMenu.title}</h2>
              <p class="mt-1 text-xs text-muted-foreground">{content.header.servicesMenu.description}</p>

              <div class="mt-3 max-h-72 space-y-2 overflow-y-auto overscroll-y-contain pe-1">
                {services.map((service) => (
                  <details class="rounded-lg border border-border bg-card p-2.5">
                    <summary class="cursor-pointer list-none text-sm font-semibold text-foreground">
                      {localizedServiceName(service.nameAr, service.nameEn)}
                    </summary>
                    <div class="mt-2 space-y-2 border-t border-border pt-2">
                      <a
                        href={getLocalizedPath(`/services/${service.slug}`, lang)}
                        class="inline-flex rounded-md border border-primary/30 px-2.5 py-1.5 text-xs font-medium text-primary"
                      >
                        {content.header.servicesMenu.viewServiceLabel}
                      </a>

                      {riyadhNeighborhoods.length > 0 && (
                        <div class="flex flex-wrap gap-1.5">
                          {riyadhNeighborhoods.slice(0, 6).map((neighborhood) => (
                            <a
                              href={getLocalizedPath(`/services/riyadh/${neighborhood.slug}`, lang)}
                              class="rounded-md border border-border px-2 py-1 text-xs text-foreground"
                            >
                              {lang === 'ar' ? neighborhood.nameAr : neighborhood.nameEn}
                            </a>
                          ))}
                        </div>
                      )}
                    </div>
                  </details>
                ))}
              </div>

              <div class="mt-3 grid gap-2">
                {servicesQuickLinks.map((link) => (
                  <a
                    href={resolveHeaderHref(link.href)}
                    class="rounded-lg border border-border bg-card px-3 py-2 text-xs font-medium text-foreground"
                  >
                    {link.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </details>

        <details class="group mt-2 rounded-xl border border-border bg-secondary/25 p-3" data-mobile-submenu>
          <summary class="flex min-h-11 cursor-pointer list-none items-center justify-between rounded-lg px-1 text-sm font-semibold text-foreground">
            <span>{content.header.carsMenu.trigger}</span>
            <svg
              class="size-4 text-muted-foreground transition-transform duration-200 group-open:rotate-180"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
            </svg>
          </summary>

          <div class="mobile-submenu-panel">
            <div class="mobile-submenu-panel-inner mt-2 border-t border-border pt-3">
              <h2 class="font-display text-base font-semibold text-foreground">{content.header.carsMenu.title}</h2>
              <p class="mt-1 text-xs text-muted-foreground">{content.header.carsMenu.description}</p>

              <div class="mt-3 max-h-72 space-y-2 overflow-y-auto overscroll-y-contain pe-1">
                {carBrands.map((brand) => (
                  <details class="rounded-lg border border-border bg-card p-2.5">
                    <summary class="cursor-pointer list-none text-sm font-semibold text-foreground">
                      {localizedBrandName(brand.nameAr, brand.nameEn)}
                    </summary>
                    <div class="mt-2 space-y-2 border-t border-border pt-2">
                      <a
                        href={getLocalizedPath(`/car-ac/${brand.slug}`, lang)}
                        class="inline-flex rounded-md border border-primary/30 px-2.5 py-1.5 text-xs font-medium text-primary"
                      >
                        {content.header.carsMenu.viewBrandLabel}
                      </a>

                      {brandsWithModelPages.has(brand.slug) ? (
                        <div class="flex flex-wrap gap-1.5">
                          {brand.models.map((model) => (
                            <a
                              href={getLocalizedPath(`/car-ac/${brand.slug}/${model.slug}`, lang)}
                              class="rounded-md border border-border px-2 py-1 text-xs text-foreground"
                            >
                              {localizedBrandName(model.nameAr, model.nameEn)}
                            </a>
                          ))}
                        </div>
                      ) : (
                        <div>
                          <div class="flex flex-wrap gap-1.5">
                            {brand.models.map((model) => (
                              <span class="rounded-md border border-border px-2 py-1 text-xs text-muted-foreground">
                                {localizedBrandName(model.nameAr, model.nameEn)}
                              </span>
                            ))}
                          </div>
                          <p class="mt-2 text-xs text-muted-foreground">{content.header.carsMenu.noModelPagesLabel}</p>
                        </div>
                      )}
                    </div>
                  </details>
                ))}
              </div>

              <div class="mt-3 grid gap-2">
                {carsQuickLinks.map((link) => (
                  <a
                    href={resolveHeaderHref(link.href)}
                    class="rounded-lg border border-border bg-card px-3 py-2 text-xs font-medium text-foreground"
                  >
                    {link.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </details>

        <ComingSoonLink
          href={getLocalizedPath('/contact', lang)}
          lang={lang}
          class="inline-flex items-center justify-center rounded-lg gold-gradient gold-shimmer px-4 py-2.5 text-sm font-semibold text-white shadow-md mt-3"
        >
          {content.header.quoteButton}
        </ComingSoonLink>

      </nav>
    </div>
  </div>
</header>

<script>
  (() => {
    const initHeaderMenus = () => {
      const header = document.querySelector('[data-site-header]');
      if (!header || header.dataset.menuBound === 'true') {
        return;
      }
      header.dataset.menuBound = 'true';

      const mobileBtn = header.querySelector('#mobile-menu-btn');
      const mobileMenu = header.querySelector('#mobile-menu');
      const mobileLinks = header.querySelectorAll('#mobile-menu a');
      const mobileDetails = Array.from(header.querySelectorAll('#mobile-menu details'));
      const mobileSubmenus = Array.from(header.querySelectorAll('#mobile-menu details[data-mobile-submenu]'));

      const closeMobileMenu = () => {
        mobileMenu?.classList.remove('is-open');
        mobileDetails.forEach((detail) => detail.removeAttribute('open'));
      };

      mobileBtn?.addEventListener('click', () => {
        const isOpen = mobileMenu?.classList.contains('is-open');
        if (isOpen) {
          closeMobileMenu();
          return;
        }
        mobileMenu?.classList.add('is-open');
      });

      mobileLinks.forEach((link) => {
        link.addEventListener('click', () => {
          closeMobileMenu();
        });
      });

      mobileSubmenus.forEach((submenu) => {
        submenu.addEventListener('toggle', () => {
          if (!(submenu instanceof HTMLDetailsElement) || !submenu.open) {
            return;
          }

          mobileSubmenus.forEach((otherSubmenu) => {
            if (otherSubmenu !== submenu && otherSubmenu instanceof HTMLDetailsElement) {
              otherSubmenu.removeAttribute('open');
            }
          });
        });
      });

      const triggers = Array.from(header.querySelectorAll('[data-menu-trigger]'));
      const panels = Array.from(header.querySelectorAll('[data-menu-panel]'));
      const chevrons = Array.from(header.querySelectorAll('[data-menu-chevron]'));

      const setPanelState = (key, isOpen) => {
        const panel = panels.find((item) => item.getAttribute('data-menu-panel') === key);
        const trigger = triggers.find((item) => item.getAttribute('data-menu-trigger') === key);
        const chevron = chevrons.find((item) => item.getAttribute('data-menu-chevron') === key);

        if (!panel || !trigger) {
          return;
        }

        panel.classList.toggle('pointer-events-none', !isOpen);
        panel.classList.toggle('invisible', !isOpen);
        panel.classList.toggle('opacity-0', !isOpen);
        panel.classList.toggle('pointer-events-auto', isOpen);
        panel.classList.toggle('visible', isOpen);
        panel.classList.toggle('opacity-100', isOpen);
        trigger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        chevron?.classList.toggle('rotate-180', isOpen);
      };

      const closeAllPanels = (exceptKey) => {
        triggers.forEach((trigger) => {
          const key = trigger.getAttribute('data-menu-trigger');
          if (!key || key === exceptKey) {
            return;
          }
          setPanelState(key, false);
        });
      };

      triggers.forEach((trigger) => {
        trigger.addEventListener('click', (event) => {
          event.stopPropagation();
          const key = trigger.getAttribute('data-menu-trigger');
          if (!key) {
            return;
          }

          const isOpen = trigger.getAttribute('aria-expanded') === 'true';
          closeAllPanels();
          setPanelState(key, !isOpen);
        });
      });

      document.addEventListener('click', (event) => {
        const target = event.target;
        if (target instanceof Node && !header.contains(target)) {
          closeMobileMenu();
          closeAllPanels();
        }
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          closeMobileMenu();
          closeAllPanels();
        }
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initHeaderMenus, { once: true });
    } else {
      initHeaderMenus();
    }
  })();
</script>
