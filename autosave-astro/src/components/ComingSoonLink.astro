---
import type { Language } from '../lib/i18n';

interface Props {
  href: string;
  lang: Language;
  class?: string;
  target?: string;
  rel?: string;
  ariaLabel?: string;
  style?: string;
  id?: string;
}

const { href, class: className, target, rel, ariaLabel, style, id } = Astro.props;
---

<a
  href={href}
  class={className}
  target={target}
  rel={rel}
  aria-label={ariaLabel}
  style={style}
  id={id}
>
  <slot />
</a>
