---
/**
 * LocalBusinessSchema — JSON-LD structured data for AutoRepair local business.
 * Injected into the <head> of every page for Google rich snippets & local map packs.
 */

interface Props {
  lang: 'ar' | 'en';
}

const { lang } = Astro.props;
const site = Astro.site?.origin ?? 'https://autosaveks.com';
const businessName = lang === 'ar' ? 'اوتو سيف - صيانة مكيف السيارة' : 'Auto Save - Car AC Service';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'AutoRepair',
  '@id': `${site}/#auto-save-riyadh`,
  'name': businessName,
  'image': `${site}/og-image.jpg`,
  'url': site,
  'telephone': '+966537133080',
  'currenciesAccepted': 'SAR',
  'availableLanguage': ['ar', 'en'],
  'address': {
    '@type': 'PostalAddress',
    'addressLocality': lang === 'ar' ? 'الرياض' : 'Riyadh',
    'addressRegion': lang === 'ar' ? 'الرياض' : 'Riyadh',
    'addressCountry': 'SA',
  },
  'geo': {
    '@type': 'GeoCoordinates',
    'latitude': 24.7136,
    'longitude': 46.6753,
  },
  'priceRange': lang === 'ar' ? 'حسب الفحص' : 'On request',
  'openingHours': 'Sa-Th 08:00-20:00',
  'openingHoursSpecification': [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Saturday', 'Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday'],
      opens: '08:00',
      closes: '20:00',
    },
  ],
  'contactPoint': [
    {
      '@type': 'ContactPoint',
      telephone: '+966537133080',
      contactType: 'customer service',
      areaServed: 'SA',
      availableLanguage: ['ar', 'en'],
    },
  ],
  'description':
    lang === 'ar'
      ? 'خدمات احترافية لإصلاح مكيف السيارة وتغيير الكمبروسر وتعبئة الفريون والصيانة الدورية. ضمان أفضل سعر عبر مراكز خدمة معتمدة.'
      : 'Professional car AC repair, compressor replacement, freon refill, and maintenance. Best price guarantee with certified service centers.',
  'areaServed': [
    { '@type': 'City', 'name': lang === 'ar' ? 'الرياض' : 'Riyadh' },
  ],
  'serviceType': [
    'Car AC Repair',
    'AC Compressor Replacement',
    'Freon Refill',
    'AC Leak Detection',
    'AC Maintenance',
    'Condenser Repair',
    'Evaporator Service',
  ],
  'hasOfferCatalog': {
    '@type': 'OfferCatalog',
    'name': lang === 'ar' ? 'خدمات مكيف السيارة' : 'Car AC Services',
    'itemListElement': [
      {
        '@type': 'Offer',
        'itemOffered': {
          '@type': 'Service',
          'name': lang === 'ar' ? 'خدمة التسليم للمركز' : 'Drop-Off Service',
          'description':
            lang === 'ar'
              ? 'تسليم السيارة للمركز مع ضمان السعر'
              : 'Drop off at workshop with coordination and price guarantee',
        },
      },
      {
        '@type': 'Offer',
        'itemOffered': {
          '@type': 'Service',
          'name': lang === 'ar' ? 'خدمة الاستلام والتسليم' : 'Pickup & Return Service',
          'description':
            lang === 'ar'
              ? 'استلام السيارة وإصلاح المكيف وإعادتها'
              : 'Pick up your car, repair the AC, and return it to you',
        },
      },
    ],
  },
  'sameAs': ['https://wa.me/966537133080'],
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
