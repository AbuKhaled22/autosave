---
/**
 * LocalBusinessSchema — JSON-LD structured data for AutoRepair local business.
 * Injected into the <head> of every page for Google rich snippets & local map packs.
 */

interface Props {
  lang: 'ar' | 'en';
}

const { lang } = Astro.props;
const site = Astro.site?.origin ?? 'https://autosaveks.com';
const businessName = lang === 'ar' ? 'اوتو سيف - صيانة مكيف السيارة' : 'Auto Save - Car AC Service';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'AutoRepair',
  'additionalType': 'https://schema.org/AutomotiveBusiness',
  '@id': `${site}/#auto-save-riyadh`,
  'name': businessName,
  'image': `${site}/og-image.jpg`,
  'url': site,
  'telephone': '+966537133080',
  'currenciesAccepted': 'SAR',
  'availableLanguage': ['ar', 'en'],
  'address': {
    '@type': 'PostalAddress',
    'streetAddress': lang === 'ar' ? 'حي الصناعية القديمة' : 'Old Industrial District',
    'addressLocality': lang === 'ar' ? 'الرياض' : 'Riyadh',
    'addressRegion': lang === 'ar' ? 'الرياض' : 'Riyadh',
    'addressCountry': 'SA',
  },
  'geo': {
    '@type': 'GeoCoordinates',
    'latitude': 24.7136,
    'longitude': 46.6753,
  },
  'priceRange': lang === 'ar' ? 'حسب الفحص' : 'On request',
  'openingHours': 'Sa-Th 08:00-20:00',
  'openingHoursSpecification': [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Saturday', 'Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday'],
      opens: '08:00',
      closes: '20:00',
    },
  ],
  'contactPoint': [
    {
      '@type': 'ContactPoint',
      telephone: '+966537133080',
      contactType: 'customer service',
      areaServed: 'SA',
      availableLanguage: ['ar', 'en'],
    },
  ],
  'description':
    lang === 'ar'
      ? 'ورشة متخصصة في مكيف السيارة في حي الصناعية القديمة بالرياض، مع فريق فني محترف وأسعار مناسبة وخدمات فحص وصيانة وإصلاح شاملة.'
      : 'Specialized car AC workshop in Riyadh Old Industrial District with experienced staff, competitive pricing, and comprehensive diagnostic and repair services.',
  'keywords': lang === 'ar'
    ? 'ورشة سيارات, مكيفات سيارات, تكييف سيارات, تصليح مكيفات, صيانة مكيفات, فحص ليزر, تعبئة فريون السيارة, فريون سيارة'
    : 'car ac repair, car ac maintenance, freon recharge, ac leak detection, workshop',
  'areaServed': [
    { '@type': 'City', 'name': lang === 'ar' ? 'الرياض' : 'Riyadh' },
  ],
  'serviceType': lang === 'ar'
    ? [
        'ورشة سيارات',
        'تصليح مكيفات سيارات',
        'تعبئة فريون السيارة',
        'فحص ليزر تسريب الفريون',
        'صيانة مكيفات',
        'تكييف سيارات',
      ]
    : [
        'Car AC Repair',
        'AC Compressor Replacement',
        'Freon Refill',
        'AC Leak Detection',
        'AC Maintenance',
        'Condenser Repair',
        'Evaporator Service',
      ],
  'hasOfferCatalog': {
    '@type': 'OfferCatalog',
    'name': lang === 'ar' ? 'خدمات مكيف السيارة' : 'Car AC Services',
    'itemListElement': [
      {
        '@type': 'Offer',
        'itemOffered': {
          '@type': 'Service',
          'name': lang === 'ar' ? 'خدمة التسليم للورشة' : 'Drop-Off Service',
          'description':
            lang === 'ar'
              ? 'تسليم السيارة للورشة مع ضمان السعر'
              : 'Drop off at workshop with managed service workflow and price guarantee',
        },
      },
      {
        '@type': 'Offer',
        'itemOffered': {
          '@type': 'Service',
          'name': lang === 'ar' ? 'خدمة الاستلام والتسليم' : 'Pickup & Return Service',
          'description':
            lang === 'ar'
              ? 'استلام السيارة وإصلاح المكيف وإعادتها'
              : 'Pick up your car, repair the AC, and return it to you',
        },
      },
    ],
  },
  'sameAs': ['https://wa.me/966537133080'],
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
