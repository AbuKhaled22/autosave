---
import type { Language } from '../lib/i18n';
import { getContentByLanguage } from '../lib/content';
import { getLocalizedPath } from '../lib/i18n';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const content = getContentByLanguage(lang);
const footer = content.footer;
const year = new Date().getFullYear();
const commercialRegistrationNumber = '1009058433';
const commercialRegistrationLabel = lang === 'ar' ? 'رقم السجل التجاري' : 'Commercial Registration Number';
const saudiLogoAlt = lang === 'ar' ? 'شعار السجل التجاري السعودي' : 'Saudi commercial registration logo';
const aiContextTitle = lang === 'ar' ? 'سياق الذكاء الاصطناعي' : 'AI Context';
const aiContextAriaLabel = lang === 'ar' ? 'روابط سياق الذكاء الاصطناعي' : 'AI context links';
const paymentMethodsTitle = lang === 'ar' ? 'التقسيط المتاح' : 'Split payments available';
const aiContextLinks = [
  { label: 'Index', href: '/llms.txt' },
  { label: 'EN', href: '/llms-en.txt' },
  { label: 'AR', href: '/llms-ar.txt' },
  { label: 'Full', href: '/llms-full.txt' },
];

function resolveFooterHref(href: string): string {
  return getLocalizedPath(href, lang);
}
---

<footer class="footer-dark text-[#f0ebe0]/90" role="contentinfo">
  {/* Gold accent top line */}
  <div class="h-1 gold-gradient"></div>

  <div class="container mx-auto px-4 py-14 lg:py-20">
    {/* Top section */}
    <section aria-label={lang === 'ar' ? 'معلومات التذييل' : 'Footer information'} class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">
      {/* Brand */}
      <div class="space-y-5">
        <a href={getLocalizedPath('/', lang)} class="inline-flex min-h-11 items-center" aria-label={lang === 'ar' ? 'العودة إلى الصفحة الرئيسية' : 'Go to homepage'}>
          {lang === 'ar' ? (
            <img src="/logo-ar.svg?v=3" alt="اوتو سيف" width="130" height="36" class="h-9 w-auto brightness-0 invert opacity-90" />
          ) : (
            <img src="/logo.svg" alt="AUTO SAVE" width="130" height="36" class="h-9 w-auto brightness-0 invert opacity-90" />
          )}
        </a>
        <p class="text-sm text-[#f0ebe0]/60 leading-relaxed">
          {footer.description}
        </p>
        <div class="inline-flex w-full max-w-[17rem] flex-col items-center gap-2.5 rounded-xl border border-white/35 bg-white px-4 py-4 shadow-md shadow-black/10">
          <img
            src="/images/saudi-logo.png"
            width="1524"
            height="1536"
            loading="lazy"
            alt={saudiLogoAlt}
            class="h-auto w-20 rounded-lg border border-border bg-white p-1.5"
          />
          <p class="text-center text-xs font-semibold leading-relaxed text-foreground">
            {commercialRegistrationLabel}: {commercialRegistrationNumber}
          </p>
        </div>
        <div class="space-y-2">
          <p class="text-xs font-semibold uppercase tracking-wider text-primary">{paymentMethodsTitle}</p>
          <div class="flex flex-wrap items-center gap-3">
            <a
              href="https://tabby.ai/ar-AE"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={lang === 'ar' ? 'الدفع عبر تابي' : 'Pay with Tabby'}
              class="inline-flex min-h-11 items-center rounded-lg border border-white/20 bg-white px-3 py-2 transition hover:border-primary/50"
            >
              <img src="/images/tabby.png" alt={lang === 'ar' ? 'شعار تابي' : 'Tabby payment logo'} width="108" height="36" loading="lazy" class="h-8 w-auto object-contain" />
            </a>
            <a
              href="https://tamara.co/ar-sa"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={lang === 'ar' ? 'الدفع عبر تمارا' : 'Pay with Tamara'}
              class="inline-flex min-h-11 items-center rounded-lg border border-white/20 bg-white px-3 py-2 transition hover:border-primary/50"
            >
              <img src="/images/tammara.png" alt={lang === 'ar' ? 'شعار تمارا' : 'Tamara payment logo'} width="108" height="36" loading="lazy" class="h-8 w-auto object-contain" />
            </a>
          </div>
        </div>
      </div>

      {/* Services */}
      <nav aria-label={footer.groups.services.title}>
        <h3 class="text-sm font-semibold text-primary mb-4 font-display uppercase tracking-wider">
          {footer.groups.services.title}
        </h3>
        <ul class="space-y-2.5">
          {footer.groups.services.links.map((link) => (
            <li>
              <a
                href={resolveFooterHref(link.href)}
                class="nav-link-hover inline-flex min-h-11 items-center text-sm text-[#f0ebe0]/60 hover:text-primary transition-colors"
                aria-label={link.name}
              >
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      {/* Resources */}
      <nav aria-label={footer.groups.resources.title}>
        <h3 class="text-sm font-semibold text-primary mb-4 font-display uppercase tracking-wider">
          {footer.groups.resources.title}
        </h3>
        <ul class="space-y-2.5">
          {footer.groups.resources.links.map((link) => (
            <li>
              <a
                href={resolveFooterHref(link.href)}
                class="nav-link-hover inline-flex min-h-11 items-center text-sm text-[#f0ebe0]/60 hover:text-primary transition-colors"
                aria-label={link.name}
              >
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      {/* Company */}
      <nav aria-label={footer.groups.company.title}>
        <h3 class="text-sm font-semibold text-primary mb-4 font-display uppercase tracking-wider">
          {footer.groups.company.title}
        </h3>
        <ul class="space-y-2.5">
          {footer.groups.company.links.map((link) => (
            <li>
              <a
                href={resolveFooterHref(link.href)}
                class="nav-link-hover inline-flex min-h-11 items-center text-sm text-[#f0ebe0]/60 hover:text-primary transition-colors"
                aria-label={link.name}
              >
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </section>

    {/* Bottom */}
    <div class="mt-14 border-t border-[#f0ebe0]/10 pt-8 flex w-full flex-col items-start justify-between gap-4 sm:flex-row sm:items-center">
      <p class="text-sm text-[#f0ebe0]/40 leading-relaxed">
        &copy; {year} {footer.copyright}
      </p>
      <div class="flex w-full flex-col items-start gap-3 sm:w-auto sm:items-end">
        <nav aria-label={lang === 'ar' ? 'روابط قانونية' : 'Legal links'} class="flex flex-wrap items-center gap-5">
          {footer.bottomLinks.map((link) => (
            <a
              href={resolveFooterHref(link.href)}
              class="nav-link-hover inline-flex min-h-11 items-center text-sm text-[#f0ebe0]/40 hover:text-primary transition-colors"
              aria-label={link.name}
            >
              {link.name}
            </a>
          ))}
        </nav>
        <nav aria-label={aiContextAriaLabel} class="flex flex-wrap items-center gap-2 text-xs">
          <span class="text-[#f0ebe0]/35">{aiContextTitle}:</span>
          {aiContextLinks.map((link) => (
            <a
              href={link.href}
              class="inline-flex min-h-8 items-center rounded border border-[#f0ebe0]/20 px-2 py-1 text-[#f0ebe0]/55 transition-colors hover:border-primary/50 hover:text-primary"
              aria-label={lang === 'ar' ? `رابط ${link.label}` : `${link.label} context link`}
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    </div>
  </div>
</footer>
