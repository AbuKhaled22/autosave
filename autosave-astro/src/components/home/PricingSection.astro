---
import type { Language } from '../../lib/i18n';
import ComingSoonLink from '../ComingSoonLink.astro';
import { DROP_OFF_CALENDLY_URL, getGeneralContactWhatsAppUrl, getPickupReturnWhatsAppUrl } from '../../lib/whatsapp';

interface Props {
  content: {
    eyebrow: string;
    title: string;
    description: string;
    popular: string;
    plans: {
      name: string;
      price?: string;
      currency?: string;
      description: string;
      cta: string;
      features: string[];
    }[];
    note: string;
  };
  lang: Language;
}

const { content, lang } = Astro.props;
const contactWhatsAppUrl = getGeneralContactWhatsAppUrl(lang);
const pickupBookingUrl = getPickupReturnWhatsAppUrl(lang);

function getPlanCtaUrl(planName: string): string {
  const name = planName.toLowerCase();
  if (name.includes('drop') || planName.includes('التسليم')) {
    return DROP_OFF_CALENDLY_URL;
  }

  if (name.includes('pickup') || planName.includes('استلام') || planName.includes('إرجاع')) {
    return pickupBookingUrl;
  }

  return contactWhatsAppUrl;
}
---

<section class="py-20 lg:py-28" id="pricing">
  <div class="container mx-auto px-4">
    <div class="text-center mb-14" data-animate="fade-in-up">
      <span class="eyebrow-decorated text-sm font-semibold uppercase tracking-widest text-accent">{content.eyebrow}</span>
      <h2 class="mt-4 text-3xl font-bold tracking-tight font-display sm:text-4xl">{content.title}</h2>
      <p class="mt-4 text-lg text-muted-foreground max-w-2xl mx-auto">{content.description}</p>
    </div>
    <div class="grid gap-8 sm:grid-cols-2 max-w-4xl mx-auto">
      {content.plans.map((plan, i) => (
        <div
          class:list={[
            'rounded-xl border p-8 relative card-hover-lift',
            i === 1 ? 'border-2 border-primary bg-gradient-to-b from-primary/8 to-primary/2 shadow-lg shadow-primary/10' : 'border-border bg-card shadow-sm',
          ]}
          data-animate="scale-in"
          data-animate-delay={String((i + 1) * 200)}
        >
          {i === 1 && (
            <span class="absolute -top-3.5 start-1/2 -translate-x-1/2 rounded-full gold-gradient px-5 py-1 text-xs font-bold text-white shadow-md">
              {content.popular}
            </span>
          )}
          <h3 class="text-xl font-bold font-display mb-3">{plan.name}</h3>
          <p class="text-sm font-semibold text-primary mb-5">{lang === 'ar' ? 'تفاصيل الرسوم عند الطلب' : 'Service fee details on request'}</p>
          <p class="text-sm text-muted-foreground mb-7">{plan.description}</p>
          <ul class="space-y-3.5 mb-8">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-2.5 text-sm">
                <svg class="h-5 w-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                <span>{feature}</span>
              </li>
            ))}
          </ul>
          <div class="mt-7 rounded-xl border border-primary/25 bg-primary/5 p-4 mb-8">
            <h4 class="text-sm font-semibold text-foreground mb-2">
              {lang === 'ar' ? 'بدون دفع فوري—قسّط براحتك' : 'No upfront cost—pay in flexible installments'}
            </h4>
            <p class="text-xs text-muted-foreground mb-3 leading-relaxed">
              {lang === 'ar' 
                ? 'نظّم ميزانيتك: قسّم كامل تكلفة الإصلاح والقطع على دفعات شهرية بدون فوائد. ادفع فقط ما تحتاج، عندما تحتاج.'
                : 'Manage your budget: split the full repair and parts cost into interest-free monthly payments. Pay only what you need, when you need it.'}
            </p>
            <p class="text-xs font-medium text-foreground mb-3">
              {lang === 'ar' ? 'شركاء بدون فوائد:' : 'Zero-interest partners:'}
            </p>
            <div class="flex flex-wrap items-center gap-2">
              <a
                href="https://tabby.ai/ar-AE"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={lang === 'ar' ? 'الدفع عبر تابي' : 'Pay with Tabby'}
                class="inline-flex min-h-10 items-center rounded-lg border border-border bg-white px-2.5 py-1.5 transition hover:border-primary/50"
              >
                <img src="/images/tabby.png" alt={lang === 'ar' ? 'شعار تابي' : 'Tabby payment logo'} width="108" height="36" loading="lazy" class="h-6 w-auto object-contain" />
              </a>
              <a
                href="https://tamara.co/ar-sa"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={lang === 'ar' ? 'الدفع عبر تمارا' : 'Pay with Tamara'}
                class="inline-flex min-h-10 items-center rounded-lg border border-border bg-white px-2.5 py-1.5 transition hover:border-primary/50"
              >
                <img src="/images/tammara.png" alt={lang === 'ar' ? 'شعار تمارا' : 'Tamara payment logo'} width="108" height="36" loading="lazy" class="h-6 w-auto object-contain" />
              </a>
            </div>
          </div>
          <ComingSoonLink
            href={getPlanCtaUrl(plan.name)}
            lang={lang}
            target="_blank"
            rel="noopener noreferrer"
            class:list={[
              'block w-full rounded-lg py-3.5 text-center text-sm font-semibold transition-all',
              i === 1
                ? 'gold-gradient gold-shimmer text-white shadow-md hover:shadow-lg hover:shadow-primary/20'
                : 'border border-primary/30 text-primary hover:bg-primary/5',
            ]}
          >
            {plan.cta}
          </ComingSoonLink>
        </div>
      ))}
    </div>
    <p class="text-center text-xs text-muted-foreground mt-8">{content.note}</p>
  </div>
</section>
