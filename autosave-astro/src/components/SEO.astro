---
/**
 * SEO component — generates canonical URL, hreflang alternates, and x-default.
 *
 * Usage:
 *   <SEO
 *     title="Page Title"
 *     description="Meta description"
 *     currentLang={currentLang}
 *     canonicalUrl={Astro.url.href}
 *     ogImage="/og-image.jpg"
 *     ogType="website"
 *   />
 */

import { getAlternateLang, getLocalizedPath, type Language } from '../lib/i18n';

interface Props {
  title: string;
  description: string;
  currentLang: Language;
  canonicalUrl: string;
  ogImage?: string;
  ogType?: string;
  keywords?: string[];
  noindex?: boolean;
}

const {
  title,
  description,
  currentLang,
  canonicalUrl,
  ogImage = '/og-image.jpg',
  ogType = 'website',
  keywords = [],
  noindex = false,
} = Astro.props;

const requestedUrl = new URL(canonicalUrl, Astro.url);
const site = Astro.site?.origin ?? requestedUrl.origin ?? 'https://autosaveks.com';
const alternateLang = getAlternateLang(currentLang);

const normalizedPathname =
  requestedUrl.pathname === '/' ? '/' : requestedUrl.pathname.replace(/\/+$/, '');
const pathWithoutLocale = normalizedPathname.replace(/^\/en(?=\/|$)/, '') || '/';

function absoluteLocalizedUrl(path: string, lang: Language): string {
  return new URL(getLocalizedPath(path, lang), site).toString();
}

const normalizedCanonicalUrl = absoluteLocalizedUrl(pathWithoutLocale, currentLang);
const alternateUrl = absoluteLocalizedUrl(pathWithoutLocale, alternateLang);
const xDefaultUrl = new URL('/', site).toString();

const ogLocale = currentLang === 'ar' ? 'ar_SA' : 'en_US';
const siteName = currentLang === 'ar' ? 'اوتو سيف' : 'AUTO SAVE';
const fullOgImage = ogImage.startsWith('http') ? ogImage : `${site}${ogImage}`;
---

{/* Canonical & hreflang */}
<link rel="canonical" href={normalizedCanonicalUrl} />
<link rel="alternate" hreflang={currentLang} href={normalizedCanonicalUrl} />
<link rel="alternate" hreflang={alternateLang} href={alternateUrl} />
<link rel="alternate" hreflang="x-default" href={xDefaultUrl} />

{/* Basic meta */}
<meta name="description" content={description} />
{keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
{noindex ? (
  <meta name="robots" content="noindex, nofollow" />
) : (
  <meta name="robots" content="index, follow" />
)}

{/* Open Graph */}
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={ogType} />
<meta property="og:url" content={normalizedCanonicalUrl} />
<meta property="og:image" content={fullOgImage} />
<meta property="og:locale" content={ogLocale} />
<meta property="og:site_name" content={siteName} />

{/* Twitter */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullOgImage} />

{/* Icons */}
<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
<link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}icon.svg`} />
