---
/**
 * CityTemplate — layout template for city landing pages.
 * Renders a full SEO-optimized page for a specific city.
 * Route: /services/[city] and /en/services/[city]
 */
import PageLayout from './PageLayout.astro';
import ProgrammaticHero from '../components/programmatic/ProgrammaticHero.astro';
import ServiceList from '../components/programmatic/ServiceList.astro';
import FAQSection from '../components/programmatic/FAQSection.astro';
import CTAWhatsApp from '../components/programmatic/CTAWhatsApp.astro';
import RelatedLinks from '../components/programmatic/RelatedLinks.astro';
import type { City } from '../data/cities';
import { services } from '../data/services';
import type { Language } from '../lib/i18n';
import { shouldNoindexThinContent } from '../lib/seo-hardening';

interface Props {
  city: City;
  lang: Language;
}

const { city, lang } = Astro.props;
const isAr = lang === 'ar';

const redactMoney = (text: string) =>
  text
    .replace(/\$\s*\d[\d,]*(?:\s*-\s*\$?\d[\d,]*)?/g, isAr ? 'حسب الفحص' : 'after inspection')
    .replace(/\d[\d,]*(?:\s*-\s*\d[\d,]*)?\s*(?:\+)?\s*(?:SAR|ريال(?:\s+سعودي)?|ر\.س)/gi, isAr ? 'حسب الفحص' : 'after inspection');

const cityName = isAr ? city.nameAr : city.nameEn;
const regionName = isAr ? city.regionAr : city.regionEn;

const pageTitle = isAr
  ? `إصلاح مكيف السيارة وتكييف السيارات في ${cityName} | اوتو سيف`
  : `Car AC Repair in ${cityName} | Auto Save`;

const pageDescription = isAr
  ? `ورشة سيارات في ${cityName} لخدمات مكيفات سيارات وتكييف سيارات تشمل تصليح مكيفات، فحص ليزر، وتعبئة فريون السيارة مع ضمان أفضل سعر.`
  : `Car AC repair and maintenance services in ${cityName}, ${regionName}. Freon recharge, compressor replacement, leak detection and more. Best price guarantee.`;

const leakLaserKeywordsAr = [
  `كشف تسريب فريون ${cityName}`,
  `فحص تسريب المكيف ${cityName}`,
  `فحص ليزر ${cityName}`,
  'فحص ليزر تسريب الفريون',
  'فحص ليزر لمكيف السيارة',
];

const leakLaserKeywordsEn = [
  `car ac leak detection ${cityName}`,
  `refrigerant leak car ${cityName}`,
  `laser leak test car ac ${cityName}`,
  'car ac laser inspection',
  'freon leak laser test',
];

const heroEyebrow = isAr ? `خدماتنا في ${cityName}` : `Our Services in ${cityName}`;
const heroTitle = isAr
  ? `إصلاح مكيف السيارة في ${cityName}`
  : `Car AC Repair in ${cityName}`;

const breadcrumbs = [
  { label: isAr ? 'الرئيسية' : 'Home', href: isAr ? '/' : '/en' },
  { label: isAr ? 'الخدمات' : 'Services', href: isAr ? '/services' : '/en/services' },
  { label: cityName },
];

const whatsappMessage = isAr
  ? `السلام عليكم، أريد حجز موعد لصيانة مكيف سيارتي في ${cityName}`
  : `Hi, I would like to book a car AC repair appointment in ${cityName}`;

const relatedCities: { title: string; href: string; description: string }[] = [];
const CITY_SERVICE_SLUGS = ['ac-recharge', 'compressor-replacement', 'leak-detection', 'ac-diagnostic', 'ac-cleaning'];
const cityServiceLinks = services
  .filter((service) => CITY_SERVICE_SLUGS.includes(service.slug))
  .map((service) => ({
  title: isAr ? `${service.nameAr} في ${cityName}` : `${service.nameEn} in ${cityName}`,
  href: isAr ? `/services/${city.slug}/${service.slug}` : `/en/services/${city.slug}/${service.slug}`,
  description: isAr ? service.descriptionAr : service.descriptionEn,
}));

// Neighborhood links (for cities with neighborhoods)
const neighborhoodLinks = city.neighborhoods.map((n) => ({
  title: isAr ? `خدمة مكيف السيارة في ${n.nameAr}` : `Car AC Service in ${n.nameEn}`,
  href: isAr
    ? `/services/${city.slug}/${n.slug}`
    : `/en/services/${city.slug}/${n.slug}`,
}));

const neighborhoodSampleAr = city.neighborhoods.slice(0, 3).map((n) => n.nameAr).join('، ');
const neighborhoodSampleEn = city.neighborhoods.slice(0, 3).map((n) => n.nameEn).join(', ');

const cityLocalIntentParagraph = isAr
  ? `إذا كنت تبحث عن ورشة سيارات في ${cityName} لخدمة مكيفات سيارات وتكييف سيارات، فالبداية الصحيحة تكون بفحص دقيق يحدد هل المشكلة في فريون السيارة، التسريب، أو أحد مكونات النظام.`
  : `If you are looking for a car workshop in ${cityName} for AC repair and maintenance, the right start is an accurate inspection to confirm whether the issue is refrigerant level, leakage, or a component fault.`;

const cityNeighborhoodIntentParagraph = isAr
  ? city.neighborhoods.length > 0
    ? `نغطي في ${cityName} عدة نطاقات خدمة مثل ${neighborhoodSampleAr}، مع نفس معايير الفحص والجودة لجميع طلبات صيانة مكيفات السيارات.`
    : `نقدم في ${cityName} خدمات فحص وتصليح مكيفات سيارات مع متابعة الأداء بعد الخدمة لضمان ثبات التبريد في أجواء المدينة.`
  : city.neighborhoods.length > 0
    ? `In ${cityName}, we cover multiple service zones such as ${neighborhoodSampleEn}, with the same inspection and quality standards for every AC request.`
    : `In ${cityName}, we provide AC inspection and repair services with post-service performance checks to ensure stable cooling in local conditions.`;

const citySchema = {
  '@context': 'https://schema.org',
  '@type': 'AutoRepair',
  name: isAr ? `اوتو سيف - ${cityName}` : `Auto Save - ${cityName}`,
  description: pageDescription,
  url: Astro.url.href,
  areaServed: {
    '@type': 'City',
    name: cityName,
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: isAr ? `خدمات مكيف السيارة في ${cityName}` : `Car AC Services in ${cityName}`,
    itemListElement: cityServiceLinks.slice(0, 4).map((link) => ({
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name: link.title,
        url: link.href,
      },
    })),
  },
};

const cityPrimaryTextLength =
  pageDescription.length +
  (isAr ? city.introAr : city.introEn).length +
  (isAr ? city.climateNoteAr : city.climateNoteEn).length +
  cityServiceLinks
    .slice(0, 4)
    .map((link) => link.description)
    .join(' ')
    .length;

const cityKeyBlockCount = [
  cityServiceLinks.length >= 3,
  city.neighborhoods.length >= 1,
  city.faqs.length >= 2,
].filter(Boolean).length;

const noindexThinCity = shouldNoindexThinContent({
  primaryTextLength: cityPrimaryTextLength,
  faqCount: city.faqs.length,
  keyBlockCount: cityKeyBlockCount,
  linkHubCount: cityServiceLinks.length + neighborhoodLinks.length + relatedCities.length,
});
---

<PageLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
  noindex={noindexThinCity}
  keywords={isAr
    ? [
        `ورشة سيارات ${cityName}`,
        `مكيفات سيارات ${cityName}`,
        `تكييف سيارات ${cityName}`,
        `تصليح مكيفات ${cityName}`,
        `صيانة مكيفات ${cityName}`,
        `فريون سيارة ${cityName}`,
        `تعبئة فريون السيارة ${cityName}`,
        `إصلاح مكيف السيارة ${cityName}`,
        ...leakLaserKeywordsAr,
      ]
    : [`car ac repair ${cityName}`, `ac service ${cityName}`, `freon recharge ${cityName}`, ...leakLaserKeywordsEn]
  }
>
  <ProgrammaticHero
    eyebrow={heroEyebrow}
    title={heroTitle}
    description={redactMoney(isAr ? city.introAr : city.introEn)}
    lang={lang}
    breadcrumbs={breadcrumbs}
  />

  {/* City intro & climate info */}
  <section class="py-20 lg:py-28" data-animate="fade-in-up">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg mx-auto max-w-none text-foreground">
        <h2 class="font-display text-2xl font-bold sm:text-3xl">
          {isAr
            ? `لماذا يحتاج مكيف سيارتك صيانة في ${cityName}؟`
            : `Why Does Your Car AC Need Service in ${cityName}?`}
        </h2>
        <p class="mt-4 text-muted-foreground">
          {redactMoney(isAr ? city.climateNoteAr : city.climateNoteEn)}
        </p>
        <p class="mt-3 text-muted-foreground">
          {cityLocalIntentParagraph}
        </p>
        <p class="mt-2 text-muted-foreground">
          {cityNeighborhoodIntentParagraph}
        </p>
        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          <div class="rounded-xl border border-border bg-card p-5 shadow-sm border-t-2 border-t-primary/25">
            <div class="text-sm font-medium text-muted-foreground">
              {isAr ? 'المنطقة' : 'Region'}
            </div>
            <div class="mt-1 font-display font-semibold text-foreground">
              {regionName}
            </div>
          </div>
          <div class="rounded-xl border border-border bg-card p-5 shadow-sm border-t-2 border-t-primary/25">
            <div class="text-sm font-medium text-muted-foreground">
              {isAr ? 'عدد السكان' : 'Population'}
            </div>
            <div class="mt-1 font-display font-semibold text-foreground">
              {city.population}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Services grid */}
  <div class="bg-secondary/40">
    <ServiceList
      lang={lang}
      title={isAr
        ? `خدمات مكيف السيارة في ${cityName}`
        : `Car AC Services in ${cityName}`}
    />
  </div>

  {cityServiceLinks.length > 0 && (
    <section class="py-20 lg:py-28" data-animate="fade-in-up">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="font-display text-2xl font-bold text-foreground sm:text-3xl">
          {isAr ? `صفحات الخدمات المحلية في ${cityName}` : `Local Service Pages in ${cityName}`}
        </h2>
        <p class="mt-4 max-w-3xl text-muted-foreground">
          {isAr
            ? `كل رابط أدناه مخصص لخدمة محددة داخل ${cityName} بهدف تقديم محتوى محلي مختلف بوضوح عن صفحات الخدمات العامة.`
            : `Each link below is dedicated to a specific service inside ${cityName} to provide clearly differentiated local content from generic service pages.`}
        </p>
        <div class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {cityServiceLinks.map((link, index) => (
            <a
              href={link.href}
              class="rounded-lg border border-border bg-card p-4 text-sm text-foreground shadow-sm transition hover:border-primary/40 hover:text-primary"
              data-animate="fade-in-up"
              data-animate-delay={String((index + 1) * 100)}
            >
              <p class="font-semibold">{link.title}</p>
              <p class="mt-1 text-muted-foreground">{redactMoney(link.description)}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Neighborhoods (if any) */}
  {neighborhoodLinks.length > 0 && (
    <section class="py-20 lg:py-28" data-animate="fade-in-up">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="mb-8 font-display text-2xl font-bold text-foreground sm:text-3xl">
          {isAr
            ? `أحياء ${cityName} التي نخدمها`
            : `${cityName} Neighborhoods We Serve`}
        </h2>
        <div class="grid gap-3 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
          {neighborhoodLinks.map((link, index) => (
            <a
              href={link.href}
              class="rounded-lg border border-border bg-card px-4 py-3 text-sm font-medium text-foreground shadow-sm transition hover:border-primary/40 hover:text-primary"
              data-animate="fade-in-up"
              data-animate-delay={String((index + 1) * 50)}
            >
              {link.title}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* FAQ */}
  <div class="bg-secondary/40">
    <FAQSection
      faqs={city.faqs}
      lang={lang}
      title={isAr
        ? `أسئلة شائعة عن مكيف السيارة في ${cityName}`
        : `FAQ About Car AC in ${cityName}`}
    />
  </div>

  {/* Related cities */}
  {relatedCities.length > 0 && (
    <RelatedLinks
      links={relatedCities}
      lang={lang}
      title={isAr ? 'خدماتنا في مدن أخرى' : 'Our Services in Other Cities'}
    />
  )}

  {/* CTA */}
  <CTAWhatsApp lang={lang} message={whatsappMessage} />

  <script type="application/ld+json" set:html={JSON.stringify(citySchema)} />
</PageLayout>
