---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLocalizedPath } from '../lib/i18n';

const lang = 'ar' as const;
const pagePath = '/car-sunroof-solutions';
const alternatePath = getLocalizedPath(pagePath, 'en');
const SUNROOF_WHATSAPP_NUMBER = '966500393753';
const buildSunroofWhatsAppUrl = (message: string) =>
  `https://wa.me/${SUNROOF_WHATSAPP_NUMBER}?text=${encodeURIComponent(message)}`;
const whatsappUrl = buildSunroofWhatsAppUrl('مرحباً، أحتاج خدمة حلول فتحة سقف السيارة لجميع الأنواع والموديلات.');

const keywords = [
  'حلول فتحات سقف السيارات',
  'تصليح فتحة سقف السيارة',
  'تصليح بانوراما السيارة',
  'إصلاح بانوراما السيارة',
  'صيانة فتحة السقف الرياض',
  'تسريب ماء فتحة السقف',
  'إصلاح تسريب فتحة السقف',
  'برمجة محرك فتحة السقف',
  'تبديل سكة فتحة السقف',
  'car sunroof solutions',
  'sunroof repair riyadh',
  'panoramic roof repair',
  'sunroof leak repair',
  'sunroof motor replacement',
  'car roof glass repair',
];

const issues = [
  {
    title: 'إصلاح تعليق فتحة السقف',
    icon: 'motor',
    description: 'معالجة توقف الفتح والإغلاق أو الحركة البطيئة عبر فحص المسارات والمحرك والتحكم الإلكتروني.',
    details: [
      'تشخيص محرك فتحة السقف ووحدة الأوامر.',
      'فحص سكة الحركة وتنظيف مسارات الانزلاق.',
      'إعادة ضبط الفتح والإغلاق الأوتوماتيكي.',
    ],
  },
  {
    title: 'حل مشكلة تسريب المياه',
    icon: 'leak',
    description: 'تنظيف مجاري التصريف واستبدال العوازل التالفة لمنع دخول الماء للفرش والدوائر الداخلية.',
    details: [
      'فحص مجاري تصريف فتحة السقف تحت ضغط ماء مباشر.',
      'تنظيف فتحات التصريف وإزالة الانسداد بالكامل.',
      'تبديل جلدة العزل التالفة واختبار الإغلاق النهائي.',
    ],
  },
  {
    title: 'صيانة البانوراما المزدوجة',
    icon: 'panorama',
    description: 'خدمة مخصصة لفتحات السقف البانورامية الكبيرة مع ضبط الحركة والتثبيت بدون أصوات مزعجة.',
    details: [
      'خدمة فتحات السقف البانورامية متعددة الأجزاء.',
      'ضبط المحاور ومزامنة الحركة بين الألواح.',
      'تقليل ضوضاء الاحتكاك والاهتزاز داخل المقصورة.',
    ],
  },
  {
    title: 'تبديل الزجاج أو العازل',
    icon: 'glass',
    description: 'استبدال زجاج السقف أو الجلدة العازلة بقطع مناسبة لكل موديل للحفاظ على الإغلاق المحكم.',
    details: [
      'تبديل زجاج فتحة السقف حسب مواصفات الموديل.',
      'استبدال العوازل المطاطية لمنع الهواء والماء.',
      'معايرة الإغلاق بعد التركيب لضمان الثبات.',
    ],
  },
  {
    title: 'إصلاح صوت الاحتكاك والاهتزاز',
    icon: 'noise',
    description: 'تشخيص أسباب الضوضاء وإعادة ضبط مسار الحركة وتثبيت القطع الداخلية بدقة.',
    details: [
      'تحديد مصدر الطقطقة أو الصرير في السقف.',
      'إعادة تثبيت مكونات المسار والحوامل الداخلية.',
      'اختبار الطريق بعد الخدمة للتأكد من هدوء الحركة.',
    ],
  },
  {
    title: 'معايرة وبرمجة النظام',
    icon: 'calibration',
    description: 'إعادة برمجة وحدات التحكم بعد الإصلاح لضمان عمل الفتحة أوتوماتيكياً بشكل صحيح.',
    details: [
      'إعادة ضبط نظام الفتح والإغلاق من وحدة التحكم.',
      'برمجة نقاط التوقف النهائية لحركة السقف.',
      'فحص استجابة الأزرار والذاكرة الإلكترونية.',
    ],
  },
];

const ownerMistakes = [
  {
    title: 'إهمال تنظيف مجاري التصريف',
    description:
      'تراكم الأتربة يمنع خروج الماء ويؤدي إلى تسريب ماء فتحة السقف داخل المقصورة، وهي من أكثر أسباب طلب تصليح فتحة سقف السيارة.',
  },
  {
    title: 'فتح وإغلاق الفتحة بعنف',
    description:
      'الاستخدام المتكرر بطريقة غير صحيحة يسرع تآكل سكة الفتحة والمسننات، ثم يتطور العطل إلى تعليق في الفتح أو الإغلاق.',
  },
  {
    title: 'تجاهل أصوات الطقطقة المبكرة',
    description:
      'الأصوات الصغيرة غالباً مؤشر بداية خلل ميكانيكي في البانوراما أو الأدلة، ومعالجتها مبكراً تقلل تكلفة إصلاح بانوراما السيارة لاحقاً.',
  },
  {
    title: 'استخدام مواد تشحيم غير مناسبة',
    description:
      'مواد غير مخصصة قد تجمع الأوساخ وتؤثر على سلاسة الحركة، وتسبب ضغطاً إضافياً على محرك فتحة السقف وحساسات الإغلاق.',
  },
];

const otherIssues = [
  {
    title: 'تلف حساس وضعية الفتحة',
    description:
      'يؤدي لتوقف الفتحة في منتصف الحركة أو العودة العكسية بشكل مفاجئ، ويحتاج فحصاً كهربائياً دقيقاً وإعادة معايرة للنظام.',
  },
  {
    title: 'خلل وحدة التحكم الإلكترونية',
    description:
      'يظهر على شكل فقدان استجابة للأزرار أو أوامر غير دقيقة للفتح والإغلاق، وغالباً يتطلب برمجة فتحة السقف بعد الإصلاح.',
  },
  {
    title: 'انحراف السكة أو كسر دليل الحركة',
    description:
      'يسبب احتكاكاً عالياً وصوتاً مزعجاً وعدم ثبات في الحركة، وقد يتطلب تبديل سكة فتحة السقف أو إعادة محاذاة دقيقة.',
  },
  {
    title: 'ضعف عزل الهواء مع السرعات العالية',
    description:
      'قد ينتج عن اهتراء العازل أو عدم محاذاة الزجاج بعد إصلاح سابق غير دقيق، ويؤثر مباشرة على الراحة والعزل داخل السيارة.',
  },
];

const faqItems = [
  {
    question: 'كم يستغرق إصلاح فتحة سقف السيارة؟',
    answer:
      'الأعطال البسيطة قد تُنجز خلال ساعة إلى ساعتين، بينما الأعطال المعقدة مثل تبديل المحرك أو مسارات البانوراما تحتاج وقتاً أطول حسب نوع السيارة.',
  },
  {
    question: 'كم تكلفة تصليح فتحة سقف السيارة في الرياض؟',
    answer:
      'التكلفة تختلف حسب نوع العطل وقطع الغيار المطلوبة. بعد الفحص نوضح حالة الفتحة، الحل المناسب، والتكلفة المتوقعة قبل بدء التنفيذ.',
  },
  {
    question: 'هل تقدمون حلولاً لكل أنواع السيارات؟',
    answer:
      'نعم، نقدم حلول فتحات سقف السيارات لمعظم الموديلات الاقتصادية والفاخرة، مع فحص مخصص لكل نوع قبل بدء العمل.',
  },
  {
    question: 'هل يمكن إصلاح تسريب الماء من فتحة السقف نهائياً؟',
    answer:
      'في أغلب الحالات نعم، يتم تنظيف وتصحيح مسارات التصريف واستبدال العوازل التالفة واختبار الإغلاق تحت ضغط الماء.',
  },
  {
    question: 'هل تشمل الخدمة فتحة السقف البانورامية؟',
    answer:
      'نعم، تشمل الخدمة فتحات السقف العادية والبانورامية مع إجراءات ضبط دقيقة للمحاور والمسارات.',
  },
  {
    question: 'هل يجب تبديل كامل فتحة السقف عند تعطلها؟',
    answer:
      'ليس دائماً. في كثير من الحالات يمكن إصلاح الجزء المتسبب بالمشكلة مثل المحرك أو السكة أو العازل دون الحاجة لتبديل النظام بالكامل.',
  },
  {
    question: 'هل يمكن القيادة والسيارة فيها تسريب من فتحة السقف؟',
    answer:
      'يفضل عدم التأخير، لأن التسريب قد يؤثر على الفرش والدوائر الكهربائية مع الوقت. الإصلاح المبكر يقلل الأضرار والتكلفة المستقبلية.',
  },
  {
    question: 'هل تقدمون فحصاً وتشخيصاً قبل الإصلاح؟',
    answer:
      'نعم، يتم الفحص الميكانيكي والكهربائي أولاً لتحديد سبب العطل بدقة، ثم شرح خطة الإصلاح المتاحة حسب حالة السيارة.',
  },
  {
    question: 'هل توجد ضمانات على إصلاح فتحة السقف؟',
    answer:
      'نعم، تختلف مدة الضمان بحسب نوع الخدمة والقطع المستخدمة، ويتم توضيح تفاصيل الضمان بشكل واضح قبل التنفيذ.',
  },
  {
    question: 'ماذا أفعل إذا علقت فتحة السقف وهي مفتوحة؟',
    answer:
      'تجنب إجبارها على الإغلاق يدوياً حتى لا يزيد الضرر. الأفضل التواصل مباشرة لتشخيص سبب التعليق وإغلاقها بطريقة آمنة.',
  },
  {
    question: 'كيف أمنع تكرار عطل فتحة السقف بعد الإصلاح؟',
    answer:
      'الالتزام بالتنظيف الدوري لمجاري التصريف، استخدام التشغيل الصحيح، وفحص الأصوات أو البطء مبكراً يساعد على منع تكرار الأعطال.',
  },
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'AutoRepair',
  name: 'حلول فتحات سقف السيارات',
  url: `https://autosaveks.com${getLocalizedPath(pagePath, lang)}`,
  description:
    'صفحة متخصصة في حلول فتحات سقف السيارات لجميع الماركات والموديلات في الرياض، تشمل إصلاح التعليق، التسريب، البانوراما، والمعايرة.',
  image: 'https://autosaveks.com/images/hero-car.jpeg',
  serviceType: [
    'Sunroof repair',
    'Panoramic roof repair',
    'Sunroof leak repair',
    'Sunroof motor calibration',
  ],
  areaServed: {
    '@type': 'City',
    name: 'Riyadh',
  },
  availableLanguage: ['ar', 'en'],
  provider: {
    '@type': 'Organization',
    name: 'AUTO SAVE',
    url: 'https://autosaveks.com',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<BaseLayout
  title="تصليح فتحة سقف السيارة الرياض | إصلاح بانوراما وتسريب الماء | Car Sunroof Solutions"
  description="تصليح فتحة سقف السيارة بالرياض، إصلاح بانوراما السيارة، حل تسريب ماء فتحة السقف، تبديل محرك وسكة السقف. Car sunroof repair Riyadh for all makes and models."
  lang={lang}
  keywords={keywords}
>
  <article class="bg-background">
    <header class="relative overflow-hidden hero-gradient text-[#f0ebe0]">
      <div class="hero-pattern"></div>
      <div class="relative z-10 mx-auto max-w-7xl px-4 py-16 sm:py-20 lg:px-8 lg:py-24">
        <p class="hero-animate inline-flex items-center rounded-full border border-primary/40 bg-[#0c1b2e]/60 px-4 py-2 text-xs font-semibold uppercase tracking-widest text-primary">
          Car sunroof solutions | حلول فتحات سقف السيارات
        </p>
        <h1 class="hero-animate hero-animate-delay-1 mt-5 max-w-4xl text-3xl font-bold tracking-tight font-display sm:text-4xl lg:text-5xl">
          حلول فتحة سقف السيارة لجميع الماركات والموديلات
        </h1>
        <p class="hero-animate hero-animate-delay-2 mt-5 max-w-3xl text-base leading-relaxed text-[#f0ebe0]/70 sm:text-lg">
            تصليح فتحة سقف السيارة، إصلاح بانوراما، علاج تسريب الماء، وتبديل محرك وسكة السقف لكل موديل.
        </p>
        <nav class="hero-animate hero-animate-delay-3 mt-8 flex flex-col gap-3 sm:flex-row sm:items-center" aria-label="روابط الإجراء السريع">
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="احجز خدمة حلول فتحة سقف السيارة عبر واتساب"
            class="inline-flex min-h-11 items-center justify-center rounded-lg gold-gradient gold-shimmer px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-primary/20 transition hover:shadow-xl"
          >
            احجز عبر واتساب
          </a>
          <a
            href={alternatePath}
            aria-label="Switch to English sunroof solutions page"
            class="inline-flex min-h-11 items-center justify-center rounded-lg border border-[#f0ebe0]/35 px-6 py-3 text-sm font-semibold text-[#f0ebe0] transition hover:bg-[#f0ebe0]/10"
          >
            English Version
          </a>
        </nav>
      </div>
    </header>

    <section class="py-20 lg:py-28">
      <div class="container mx-auto px-4">
        <header class="max-w-3xl" data-animate="fade-in-up">
          <h2 class="text-3xl font-bold tracking-tight font-display sm:text-4xl">الخدمات الأعلى طلباً لفتحات سقف السيارات</h2>
          <p class="mt-4 text-base leading-relaxed text-muted-foreground sm:text-lg">
            ندعم جميع أنواع وموديلات السيارات، وننفذ حلول فتحة السقف من الأعطال البسيطة حتى الأعطال المعقدة بخطة تشخيص واضحة.
          </p>
        </header>
        <ul class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
          {issues.map((issue, index) => (
            <li data-animate="fade-in-up" data-animate-delay={String(((index % 3) + 1) * 100)}>
              <button
                type="button"
                aria-label={`عرض تفاصيل خدمة ${issue.title}`}
                data-service-title={issue.title}
                data-service-icon={issue.icon}
                data-service-description={issue.description}
                data-service-details={JSON.stringify(issue.details)}
                class="w-full rounded-xl border border-border bg-card p-6 text-start shadow-sm card-hover-lift border-t-2 border-t-primary/25 transition hover:border-t-primary/60"
              >
                <div class="flex items-start gap-3">
                  <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
                      {issue.icon === 'motor' && <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21m-5.83-5.83L3 21m12-9.75l3-3a2.121 2.121 0 013 3l-3 3m-6 0l4.5-4.5" />}
                      {issue.icon === 'leak' && <path stroke-linecap="round" stroke-linejoin="round" d="M12 3.75c-1.172 0-6 5.273-6 8.25a6 6 0 0012 0c0-2.977-4.828-8.25-6-8.25z" />}
                      {issue.icon === 'panorama' && <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 7.5h16.5v9H3.75v-9zm4.5 0v9m7.5-9v9" />}
                      {issue.icon === 'glass' && <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5h15M7.5 19.5v-3.75a4.5 4.5 0 019 0v3.75" />}
                      {issue.icon === 'noise' && <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12h3m10.5 0h3M7.5 8.25l2.25 3.75-2.25 3.75m9-7.5l-2.25 3.75 2.25 3.75" />}
                      {issue.icon === 'calibration' && <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 6.75h15M4.5 12h15M4.5 17.25h15M9 5.25v3M15 10.5v3m-3.75 2.25v3" />}
                    </svg>
                  </span>
                  <h3 class="pt-1 text-lg font-semibold font-display">{issue.title}</h3>
                </div>
                <p class="mt-3 text-sm leading-relaxed text-muted-foreground">{issue.description}</p>
                <span class="mt-4 inline-flex min-h-11 items-center rounded-lg border border-primary/30 px-4 py-2 text-xs font-semibold text-primary">
                  عرض التفاصيل
                </span>
              </button>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section
      id="service-modal-overlay"
      class="service-modal-overlay fixed inset-0 z-50 bg-foreground/65 p-4 sm:p-6"
      aria-label="نافذة تفاصيل الخدمة"
    >
      <article
        id="service-modal-panel"
        role="dialog"
        aria-modal="true"
        aria-labelledby="service-modal-title"
        class="service-modal-panel mx-auto mt-8 w-full max-w-2xl rounded-2xl border border-border bg-card p-5 shadow-2xl sm:mt-12 sm:p-8"
      >
        <header class="flex items-start justify-between gap-4">
          <div class="flex items-start gap-3">
            <span id="service-modal-icon-wrap" class="mt-1 inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
                <path id="service-modal-icon-path" stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21m-5.83-5.83L3 21m12-9.75l3-3a2.121 2.121 0 013 3l-3 3m-6 0l4.5-4.5" />
              </svg>
            </span>
            <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-primary">Service Detail</p>
            <h3 id="service-modal-title" class="mt-2 text-2xl font-bold tracking-tight font-display">تفاصيل الخدمة</h3>
            </div>
          </div>
          <button
            id="service-modal-close"
            type="button"
            aria-label="إغلاق نافذة تفاصيل الخدمة"
            class="inline-flex min-h-11 min-w-11 items-center justify-center rounded-lg border border-border bg-secondary/50 text-foreground transition hover:bg-secondary"
          >
            ×
          </button>
        </header>

        <p id="service-modal-description" class="mt-4 text-sm leading-relaxed text-muted-foreground sm:text-base"></p>

        <section class="mt-6 rounded-xl bg-secondary/40 p-4 sm:p-5">
          <h4 class="text-sm font-semibold font-display">ماذا تشمل الخدمة؟</h4>
          <ul id="service-modal-points" class="mt-3 space-y-2 text-sm text-muted-foreground"></ul>
        </section>

        <footer class="mt-7 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="احجز خدمة فتحة السقف عبر واتساب"
            class="inline-flex min-h-11 items-center justify-center rounded-lg gold-gradient gold-shimmer px-6 py-3 text-sm font-semibold text-white shadow-md"
          >
            احجز هذه الخدمة
          </a>
          <button
            id="service-modal-close-secondary"
            type="button"
            aria-label="إغلاق نافذة التفاصيل"
            class="inline-flex min-h-11 items-center justify-center rounded-lg border border-primary/30 px-6 py-3 text-sm font-semibold text-primary transition hover:bg-primary/5"
          >
            إغلاق
          </button>
        </footer>
      </article>
    </section>

    <section class="bg-secondary/40 py-20 lg:py-28">
      <div class="container mx-auto px-4">
