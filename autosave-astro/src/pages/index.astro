---
import PageLayout from '../layouts/PageLayout.astro';
import HeroSection from '../components/home/HeroSection.astro';
import TrustBadges from '../components/home/TrustBadges.astro';
import BenefitsSection from '../components/home/BenefitsSection.astro';
import HowItWorks from '../components/home/HowItWorks.astro';
import PricingSection from '../components/home/PricingSection.astro';
import FaqSection from '../components/home/FaqSection.astro';
import CtaSection from '../components/home/CtaSection.astro';
import BlogPreview from '../components/home/BlogPreview.astro';
import { getContentByLanguage } from '../lib/content';
import { getBlogPosts } from '../lib/blog-data';
import WebsiteSchema from '../components/WebsiteSchema.astro';
import FAQSchema from '../components/FAQSchema.astro';

const lang = 'ar' as const;
const content = getContentByLanguage(lang);
const blogPosts = getBlogPosts(lang).slice(0, 3);
const homePageUrl = 'https://autosaveks.com/';
const productImageUrl = 'https://autosaveks.com/images/blog/ac-compressor-guide.jpeg';
const priceValidUntil = `${new Date().getFullYear() + 1}-12-31`;
const aggregateRating = {
  ratingValue: '4.8',
  reviewCount: '320',
  ratingCount: '320',
  bestRating: '5',
  worstRating: '1',
};
---

<PageLayout
  title="ورشة سيارات لصيانة مكيفات وتكييف السيارات | اوتو سيف"
  description="ورشة سيارات متخصصة في مكيفات سيارات: تصليح مكيفات، فحص ليزر، تعبئة فريون السيارة، وصيانة مكيفات مع ضمان أفضل سعر في الرياض."
  lang={lang}
  keywords={['ورشة سيارات', 'مكيفات سيارات', 'تكييف سيارات', 'تصليح مكيفات', 'صيانة مكيفات', 'فحص ليزر', 'تعبئة فريون السيارة', 'فريون سيارة', 'فريون مكيف', 'إصلاح مكيف السيارة']}
>
  <HeroSection content={content.home.hero} lang={lang} />
  <section class="py-8" data-animate="fade-in-up">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <p class="text-sm text-muted-foreground">
        تقييم العملاء {aggregateRating.ratingValue} من {aggregateRating.bestRating} بناءً على {aggregateRating.reviewCount} مراجعة.
      </p>
    </div>
  </section>
  <TrustBadges items={content.home.trustBadges} />
  <section class="bg-secondary/40 py-12 lg:py-16" data-animate="fade-in-up">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold tracking-tight font-display sm:text-3xl">خدمات مكيفات سيارات الأكثر بحثاً</h2>
      <p class="mt-3 max-w-3xl text-muted-foreground">
        نوفر حلول ورشة سيارات متخصصة تشمل تكييف سيارات، تصليح مكيفات، تعبئة فريون السيارة، وفحص ليزر لكشف التسريبات بدقة.
      </p>
      <ul class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        <li>
          <a href="/services/ac-recharge" class="block rounded-lg border border-border bg-card p-4 text-sm font-semibold text-foreground shadow-sm transition hover:border-primary/40 hover:text-primary" aria-label="تعبئة فريون السيارة وفريون مكيف">
            تعبئة فريون السيارة وفريون مكيف
          </a>
        </li>
        <li>
          <a href="/services/leak-detection" class="block rounded-lg border border-border bg-card p-4 text-sm font-semibold text-foreground shadow-sm transition hover:border-primary/40 hover:text-primary" aria-label="فحص ليزر وكشف تسريب فريون">
            فحص ليزر وكشف تسريب فريون
          </a>
        </li>
        <li>
          <a href="/services/ac-diagnostic" class="block rounded-lg border border-border bg-card p-4 text-sm font-semibold text-foreground shadow-sm transition hover:border-primary/40 hover:text-primary" aria-label="تصليح مكيفات سيارات بعد التشخيص">
            تصليح مكيفات سيارات بعد التشخيص
          </a>
        </li>
        <li>
          <a href="/services/ac-cleaning" class="block rounded-lg border border-border bg-card p-4 text-sm font-semibold text-foreground shadow-sm transition hover:border-primary/40 hover:text-primary" aria-label="صيانة مكيفات وتكييف سيارات">
            صيانة مكيفات وتكييف سيارات
          </a>
        </li>
        <li>
          <a href="/services/compressor-replacement" class="block rounded-lg border border-border bg-card p-4 text-sm font-semibold text-foreground shadow-sm transition hover:border-primary/40 hover:text-primary" aria-label="إصلاح مكيف السيارة وتغيير الكمبروسر">
            إصلاح مكيف السيارة وتغيير الكمبروسر
          </a>
        </li>
        <li>
          <a href="/contact" class="block rounded-lg border border-border bg-card p-4 text-sm font-semibold text-foreground shadow-sm transition hover:border-primary/40 hover:text-primary" aria-label="حجز ورشة سيارات لصيانة المكيف">
            حجز ورشة سيارات لصيانة المكيف
          </a>
        </li>
      </ul>
    </div>
  </section>
  <BenefitsSection content={content.home.benefits} />
  <HowItWorks content={content.home.howItWorks} />
  <PricingSection content={content.home.pricing} lang={lang} />
  <BlogPreview content={content.home.blogPreview} posts={blogPosts} lang={lang} />
  <FaqSection content={content.home.faq} />
  <CtaSection content={content.home.cta} lang={lang} />
  <WebsiteSchema lang={lang} />
  <FAQSchema items={content.home.faq.items} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "@id": `${homePageUrl}#service-product`,
    "mainEntityOfPage": homePageUrl,
    "name": "خدمات صيانة مكيف السيارة",
    "description": "خدمات احترافية لإصلاح مكيف السيارة وتغيير الكمبروسر وتعبئة الفريون والصيانة الدورية.",
    "image": [productImageUrl],
    "url": homePageUrl,
    "brand": {
      "@type": "Brand",
      "name": "اوتو سيف",
      "url": "https://autosaveks.com"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": aggregateRating.ratingValue,
      "reviewCount": aggregateRating.reviewCount,
      "ratingCount": aggregateRating.ratingCount,
      "bestRating": aggregateRating.bestRating,
      "worstRating": aggregateRating.worstRating
    },
    "offers": {
      "@type": "Offer",
      "url": homePageUrl,
      "price": "150",
      "priceCurrency": "SAR",
      "priceValidUntil": priceValidUntil,
      "shippingDetails": {
        "@type": "OfferShippingDetails",
        "shippingRate": {
          "@type": "MonetaryAmount",
          "value": "0",
          "currency": "SAR"
        },
        "shippingDestination": {
          "@type": "DefinedRegion",
          "addressCountry": "SA"
        },
        "deliveryTime": {
          "@type": "ShippingDeliveryTime",
          "handlingTime": {
            "@type": "QuantitativeValue",
            "minValue": 0,
            "maxValue": 1,
            "unitCode": "DAY"
          },
          "transitTime": {
            "@type": "QuantitativeValue",
            "minValue": 0,
            "maxValue": 1,
            "unitCode": "DAY"
          }
        }
      },
      "hasMerchantReturnPolicy": {
        "@type": "MerchantReturnPolicy",
        "applicableCountry": "SA",
        "returnPolicyCategory": "https://schema.org/MerchantReturnNotPermitted"
      },
      "availability": "https://schema.org/InStock"
    }
  })} />
</PageLayout>
