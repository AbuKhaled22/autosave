---
import PageLayout from '../../layouts/PageLayout.astro';
import { getContentByLanguage } from '../../lib/content';
import ComingSoonLink from '../../components/ComingSoonLink.astro';
import { DROP_OFF_CALENDLY_URL, getGeneralContactWhatsAppUrl, getPickupReturnWhatsAppUrl, WHATSAPP_DISPLAY_NUMBER } from '../../lib/whatsapp';

const lang = 'en' as const;
const content = getContentByLanguage(lang);
const contact = content.contact;
const dropOffBookingUrl = DROP_OFF_CALENDLY_URL;
const pickupBookingUrl = getPickupReturnWhatsAppUrl(lang);
const generalWhatsappUrl = getGeneralContactWhatsAppUrl(lang);
const aiContextLinks = [
  { label: 'Index', href: '/llms.txt' },
  { label: 'EN', href: '/llms-en.txt' },
  { label: 'AR', href: '/llms-ar.txt' },
  { label: 'Full', href: '/llms-full.txt' },
];
---

<PageLayout
  title="Contact Us | Request Car AC Service"
  description="Request a car AC repair service, get a free quote, or reach us on WhatsApp. Certified service centers, best price guarantee, and pickup service available."
  lang={lang}
  keywords={['contact car AC repair', 'request AC service', 'car AC repair quote', 'auto AC service near me']}
>
  {/* Hero */}
  <section class="relative overflow-hidden hero-gradient text-[#f0ebe0]">
    <div class="hero-pattern"></div>
    <div class="relative z-10 mx-auto max-w-7xl px-4 py-16 lg:px-8 lg:py-24">
      <span class="hero-animate eyebrow-decorated text-sm font-semibold uppercase tracking-widest text-primary">{contact.heroEyebrow}</span>
      <h1 class="hero-animate hero-animate-delay-1 mt-4 text-4xl font-bold tracking-tight font-display sm:text-5xl">{contact.heroTitle}</h1>
      <p class="hero-animate hero-animate-delay-2 mt-6 text-lg text-[#f0ebe0]/65 max-w-2xl">{contact.heroDescription}</p>
    </div>
  </section>

  {/* Booking + Info */}
  <section class="py-20 lg:py-28">
    <div class="container mx-auto px-4">
      <div class="grid gap-12 lg:grid-cols-2">
        {/* Booking options */}
        <div data-animate="fade-in-up">
          <h2 class="text-2xl font-bold font-display mb-2">{contact.formTitle}</h2>
          <p class="text-muted-foreground mb-8">{contact.formDescription}</p>

          <div class="space-y-6">
            {/* Drop-off */}
            <div class="rounded-xl border border-border bg-card p-7 shadow-sm card-hover-lift border-t-2 border-t-primary/25">
              <h3 class="text-lg font-semibold mb-1 font-display">{contact.dropOff}</h3>
              <p class="text-sm text-muted-foreground">Drive to the workshop and we handle coordination, repair, and the best spare-part pricing.</p>
              <div class="mt-5 rounded-xl border border-primary/25 bg-primary/5 p-4">
                <h4 class="text-sm font-semibold text-foreground mb-2">No upfront cost—pay in flexible installments</h4>
                <p class="text-xs text-muted-foreground mb-3 leading-relaxed">Split the repair and parts cost into comfortable monthly payments with zero interest, fast approval, and a clear plan.</p>
                <p class="text-xs font-medium text-foreground mb-3">Zero-interest partners:</p>
                <div class="flex flex-wrap items-center gap-2">
                  <a href="https://tabby.ai/ar-AE" target="_blank" rel="noopener noreferrer" aria-label="Pay with Tabby" class="inline-flex min-h-10 items-center rounded-lg border border-border bg-white px-2.5 py-1.5 transition hover:border-primary/50">
                    <img src="/images/tabby.png" alt="Tabby payment logo" width="108" height="36" loading="lazy" class="h-6 w-auto object-contain" />
                  </a>
                  <a href="https://tamara.co/ar-sa" target="_blank" rel="noopener noreferrer" aria-label="Pay with Tamara" class="inline-flex min-h-10 items-center rounded-lg border border-border bg-white px-2.5 py-1.5 transition hover:border-primary/50">
                    <img src="/images/tammara.png" alt="Tamara payment logo" width="108" height="36" loading="lazy" class="h-6 w-auto object-contain" />
                  </a>
                </div>
              </div>
              <ul class="mt-5 space-y-3">
                <li class="flex items-start gap-3"><svg class="h-5 w-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg><span class="text-sm">Search for the best parts at the cheapest price, with a guarantee to return triple the price difference if any.</span></li>
                <li class="flex items-start gap-3"><svg class="h-5 w-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg><span class="text-sm">Price match guarantee</span></li>
                <li class="flex items-start gap-3"><svg class="h-5 w-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg><span class="text-sm">Quality-checked repair</span></li>
                <li class="flex items-start gap-3"><svg class="h-5 w-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg><span class="text-sm">Dedicated WhatsApp support</span></li>
                <li class="flex items-start gap-3"><svg class="h-5 w-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg><span class="text-sm">Service warranty included</span></li>
                <li class="flex items-start gap-3"><svg class="h-5 w-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg><span class="text-sm">Free part delivery</span></li>
              </ul>
              <ComingSoonLink
                href={dropOffBookingUrl}
                lang={lang}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-5 inline-flex w-full items-center justify-center rounded-lg border border-primary/30 px-6 py-3 text-sm font-semibold text-primary transition hover:bg-primary/5"
              >
                {contact.bookNow}
              </ComingSoonLink>
            </div>

            {/* Pickup */}
            <div class="rounded-xl border-2 border-primary bg-gradient-to-b from-primary/8 to-primary/2 p-7 shadow-lg shadow-primary/10 card-hover-lift">
              <h3 class="text-lg font-semibold mb-1 font-display">{contact.pickup}</h3>
              <p class="text-sm text-muted-foreground">We pick up your car, complete the repair at a workshop, and return it after quality inspection.</p>
              <div class="mt-5 rounded-xl border border-primary/25 bg-primary/5 p-4">
                <h4 class="text-sm font-semibold text-foreground mb-2">Spread costs over time—zero interest</h4>
                <p class="text-xs text-muted-foreground mb-3 leading-relaxed">Avoid a large one-time bill: divide the total repair and parts investment into easy monthly installments at zero percent interest.</p>
                <p class="text-xs font-medium text-foreground mb-3">Trusted payment plans:</p>
                <div class="flex flex-wrap items-center gap-2">
                  <a href="https://tabby.ai/ar-AE" target="_blank" rel="noopener noreferrer" aria-label="Pay with Tabby" class="inline-flex min-h-10 items-center rounded-lg border border-border bg-white px-2.5 py-1.5 transition hover:border-primary/50">
                    <img src="/images/tabby.png" alt="Tabby payment logo" width="108" height="36" loading="lazy" class="h-6 w-auto object-contain" />
                  </a>
                  <a href="https://tamara.co/ar-sa" target="_blank" rel="noopener noreferrer" aria-label="Pay with Tamara" class="inline-flex min-h-10 items-center rounded-lg border border-border bg-white px-2.5 py-1.5 transition hover:border-primary/50">
                    <img src="/images/tammara.png" alt="Tamara payment logo" width="108" height="36" loading="lazy" class="h-6 w-auto object-contain" />
                  </a>
                </div>
              </div>
              <ul class="mt-5 space-y-3">
                <li class="flex items-start gap-3"><svg class="h-5 w-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg><span class="text-sm">Door-to-door car pickup</span></li>
                <li class="flex items-start gap-3"><svg class="h-5 w-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg><span class="text-sm">Search for the best parts at the cheapest price, with a guarantee to return triple the price difference if any.</span></li>
                <li class="flex items-start gap-3"><svg class="h-5 w-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg><span class="text-sm">Price match guarantee</span></li>
                <li class="flex items-start gap-3"><svg class="h-5 w-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg><span class="text-sm">Quality-checked repair</span></li>
                <li class="flex items-start gap-3"><svg class="h-5 w-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg><span class="text-sm">Dedicated WhatsApp support</span></li>
                <li class="flex items-start gap-3"><svg class="h-5 w-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg><span class="text-sm">Service warranty included</span></li>
                <li class="flex items-start gap-3"><svg class="h-5 w-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg><span class="text-sm">Car delivered back to you</span></li>
                <li class="flex items-start gap-3"><svg class="h-5 w-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg><span class="text-sm">Free part delivery</span></li>
              </ul>
              <ComingSoonLink
                href={pickupBookingUrl}
                lang={lang}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-5 inline-flex w-full items-center justify-center rounded-lg gold-gradient gold-shimmer px-6 py-3 text-sm font-semibold text-white shadow-md transition hover:shadow-lg hover:shadow-primary/20"
              >
                {contact.bookNow}
              </ComingSoonLink>
            </div>
          </div>

          <p class="mt-5 text-xs text-muted-foreground">{contact.pricingNote}</p>

          {/* WhatsApp direct */}
          <div class="mt-8 rounded-xl border border-border bg-secondary/40 p-7">
            <h3 class="text-lg font-semibold mb-2 font-display">{contact.whatsappTitle}</h3>
            <p class="text-sm text-muted-foreground mb-4">{contact.whatsappDescription}</p>
            <ComingSoonLink
              href={generalWhatsappUrl}
              lang={lang}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center rounded-lg bg-[#25D366] px-6 py-3 text-sm font-semibold text-white shadow-md shadow-[#25D366]/20 transition hover:bg-[#1ebe5d] hover:shadow-lg"
            >
              {contact.openWhatsapp}
            </ComingSoonLink>

            <div class="mt-4 rounded-lg border border-border/70 bg-background/70 p-4">
              <h4 class="text-xs font-semibold font-display uppercase tracking-wider text-primary">AI Context</h4>
              <p class="mt-1 text-xs text-muted-foreground">Discovery links for AI assistants and context crawlers.</p>
              <nav aria-label="AI context links" class="mt-2 flex flex-wrap gap-2">
                {aiContextLinks.map((link) => (
                  <a
                    href={link.href}
                    class="inline-flex min-h-8 items-center rounded border border-border px-2 py-1 text-xs text-muted-foreground transition-colors hover:border-primary/40 hover:text-primary"
                    aria-label={`${link.label} context link`}
                  >
                    {link.label}
                  </a>
                ))}
              </nav>
            </div>
          </div>
        </div>

        {/* Contact info */}
        <div class="space-y-8" data-animate="fade-in-up" data-animate-delay="200">
          <div class="rounded-xl border border-border bg-card p-6 shadow-sm">
            <h3 class="text-lg font-semibold mb-4 font-display">{contact.contactInfoTitle}</h3>
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-primary/10">
                  <svg class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
                </div>
                <div>
                  <div class="text-sm font-medium">{contact.phoneLabel}</div>
                  <a href={generalWhatsappUrl} target="_blank" rel="noopener noreferrer" class="text-sm text-muted-foreground hover:text-primary transition-colors">{WHATSAPP_DISPLAY_NUMBER}</a>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-primary/10">
                  <svg class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
                </div>
                <div>
                  <div class="text-sm font-medium">{contact.serviceAreaLabel}</div>
                  <div class="text-sm text-muted-foreground">{contact.serviceAreaValue}</div>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-primary/10">
                  <svg class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </div>
                <div>
                  <div class="text-sm font-medium">{contact.hoursLabel}</div>
                  <div class="text-sm text-muted-foreground">{contact.hoursWeek}</div>
                  <div class="text-sm text-muted-foreground">{contact.hoursWeekend}</div>
                </div>
              </div>
            </div>
          </div>

          {/* Guarantees */}
          <div class="rounded-xl border border-border bg-card p-6 shadow-sm">
            <h3 class="text-lg font-semibold mb-4 font-display">{contact.guaranteeTitle}</h3>
            <ul class="space-y-3">
              {contact.guarantees.map((g) => (
                <li class="flex items-center gap-2.5 text-sm">
                  <svg class="h-5 w-5 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  {g}
                </li>
              ))}
            </ul>
          </div>

          {/* Cities */}
          <div class="rounded-xl border border-border bg-card p-6 shadow-sm">
            <h3 class="text-lg font-semibold mb-2 font-display">{contact.citiesTitle}</h3>
            <p class="text-sm text-muted-foreground mb-3">{contact.citiesDescription}</p>
            <div class="flex flex-wrap gap-2">
              {contact.cities.map((city) => (
                <span class="rounded-full bg-primary/10 px-4 py-1.5 text-sm font-medium text-primary border border-primary/20">
                  {city}
                </span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
